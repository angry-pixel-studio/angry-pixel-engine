{
    "name": "angry-pixel-monorepo",
    "version": "1.0.0",
    "description": "Angry Pixel Engine Monorepo",
    "private": true,
    "author": "Mauro Cristy <maurocristy@gmail.com>",
    "license": "MIT",
    "workspaces": [
        "packages/*",
        "bundles/*",
        "demos/*"
    ],
    "scripts": {
        "build": "yarn workspace @angry-pixel/engine build",
        "build:types": "yarn workspace @angry-pixel/engine build:types",
        "lint": "eslint .",
        "lint-and-fix": "eslint . --fix",
        "prettier-format": "prettier --write \"packages/*/src/**/*.ts\"",
        "prettier-check": "prettier --check \"packages/*/src/**/*.ts\"",
        "publish": "yarn run build && yarn workspace angry-pixel publish",
        "api-docs": "yarn run build:types && yarn workspace @angry-pixel/engine typedoc",
        "docs": "cd docs && mkdocs build",
        "deploy-docs": "scripts/deploy-docs-rsync.sh",
        "deploy-api-docs": "scripts/deploy-api-docs-rsync.sh",
        "demo:platformer": "yarn workspace @angry-pixel/platformer dev",
        "demo:shmup": "yarn workspace @angry-pixel/shmup dev"
    },
    "devDependencies": {
        "eslint": "^9.2.0",
        "prettier": "^3.2.5",
        "tslib": "^2.8.1",
        "typedoc": "^0.28.19",
        "typedoc-plugin-markdown": "^4.2.8",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.0"
    }
}
